# Life Planner Environment Variables
# Copy this file to .env and update the values

# ==================== Application ====================
APP_NAME=Life Planner
APP_VERSION=1.0.0
DEBUG=true

# ==================== Server ====================
HOST=0.0.0.0
PORT=8000

# ==================== Database ====================
# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./life_planner.db

# PostgreSQL (Production) - uncomment and update when using PostgreSQL
# DATABASE_URL=postgresql+asyncpg://lifeplanner:lifeplanner123@localhost:5432/life_planner

DB_USER=lifeplanner
DB_PASSWORD=lifeplanner123
DB_NAME=life_planner

# ==================== JWT Authentication ====================
# IMPORTANT: Change this to a secure random string in production!
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# ==================== CORS ====================
# Comma-separated list of allowed origins (no spaces around commas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== AI Services ====================
# Anthropic Claude API Key (optional - for mistake analysis)
ANTHROPIC_API_KEY=

# ==================== File Upload ====================
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# ==================== PaddleOCR ====================
PADDLEOCR_USE_GPU=false
PADDLEOCR_LANG=ch

# ==================== Frontend ====================
# Vite dev server URL (for CORS)
VITE_API_BASE_URL=http://localhost:8000/api

# ==================== Docker ====================
# Docker Compose profiles
COMPOSE_PROFILES=

# ==================== Logging ====================
LOG_LEVEL=INFO
LOG_DIR=logs

# ==================== Security ====================
# Enable rate limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60

# ==================== Feature Flags ====================
# Enable/disable features
ENABLE_HOLLAND_TEST=true
ENABLE_MISTAKE_ANALYSIS=true
ENABLE_COLLEGE_RECOMMENDATION=true
